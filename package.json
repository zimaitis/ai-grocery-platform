{
  "name": "ai-grocery-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @ai-grocery/db db:generate",
    "db:migrate": "pnpm --filter @ai-grocery/db db:migrate",
    "db:seed": "pnpm --filter @ai-grocery/db db:seed",
    "barbora:check-session": "tsx scripts/barbora/orders-api-to-files.ts check-session",
    "barbora:orders-api-to-files": "tsx scripts/barbora/orders-api-to-files.ts collect",
    "barbora:categories-json-to-db": "pnpm --filter @ai-grocery/barbora-importer categories-json-to-db",
    "barbora:orders-files-to-db": "# TODO: .tmp/barbora -> SourceDocument, Purchase, PurchaseItem, StoreProduct",
    "barbora:products-api-to-db": "# TODO: Barbora product/category/search API -> StoreProduct enrichment",
    "barbora:documents-api-to-files": "# TODO: Barbora invoice/waybill PDF API -> .tmp/barbora/documents"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "turbo": "^2.5.1",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
