{
  "name": "ai-grocery-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @ai-grocery/db db:generate",
    "db:migrate": "pnpm --filter @ai-grocery/db db:migrate",
    "db:seed": "pnpm --filter @ai-grocery/db db:seed",
    "barbora:check-session": "tsx scripts/barbora/orders-collect.ts check-session",
    "barbora:orders-collect": "tsx scripts/barbora/orders-collect.ts collect",
    "barbora:taxonomy-import": "pnpm --filter @ai-grocery/barbora-importer taxonomy-import",
    "barbora:purchases-import": "# TODO: import .tmp/barbora -> SourceDocument/Purchase/PurchaseItem",
    "barbora:products-enrich": "# TODO: enrich products with AI",
    "barbora:documents-collect": "# TODO: download PDF invoices"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "turbo": "^2.5.1",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
