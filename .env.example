# Database
DATABASE_URL="postgresql://ai_grocery:ai_grocery_password@localhost:5432/ai_grocery"

# Barbora
BARBORA_API_BASE_URL=https://barbora.lt
BARBORA_COOKIE=
BARBORA_CUSTOMER_ID=
BARBORA_LIMIT=5
BARBORA_MAX_PAGES=1
BARBORA_FETCH_DETAILS=true
BARBORA_OUTPUT_DIR=.tmp/barbora
BARBORA_REQUEST_DELAY_MS=500
BARBORA_AUTH_HEADER=
BARBORA_AUTH_TOKEN=
